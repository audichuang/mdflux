{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDFlux",
  "version": "0.1.1",
  "identifier": "com.projektvisyo.mdflux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "MDFlux",
        "width": 960,
        "height": 680,
        "minWidth": 680,
        "minHeight": 520,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "ibrahimqureshae",
    "copyright": "© 2026 ibrahimqureshae",
    "category": "Productivity",
    "shortDescription": "Convert documents to clean Markdown — offline.",
    "longDescription": "MDFlux turns PDFs, Office files, and more into clean Markdown. The offline installer bundles a private Python runtime and MarkItDown so conversion works with no first-launch download. Optional OCR/audio engines are not included in the basic offline build.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/sidecar/*",
      "resources/sidecar/requirements.lock",
      "resources/sidecar/requirements-ocr.lock",
      "resources/sidecar/requirements-audio.lock",
      "resources/runtime/**/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
